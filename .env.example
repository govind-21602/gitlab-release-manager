# ─────────────────────────────────────────────────────────────────────────────
# GitLab Release Manager — environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# GitLab instance base URL (no trailing slash)
GITLAB_URL=https://gitlab.com

# Personal Access Token with api scope
GITLAB_TOKEN=your-personal-access-token

# Numeric project ID or URL-encoded namespace/project
PROJECT_ID=12345678

# Branch to compare FROM (the "newer" branch)
SOURCE_BRANCH=develop

# Branch to compare TO (the "stable" branch)
TARGET_BRANCH=staging

# Directory where CSV / Excel / JSON reports will be written
OUTPUT_DIR=reports/

# Directory where log files will be written
LOG_DIR=logs/
